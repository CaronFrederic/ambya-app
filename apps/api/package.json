{
  "scripts": {
    "start:dev": "nest start --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed:dev": "tsx prisma/seed/main.seed.ts dev",
    "seed:test": "dotenv -e .env.test -- tsx prisma/seed/main.seed.ts test",
    "seed:demo": "dotenv -e .env.demo -- tsx prisma/seed/main.seed.ts demo",
    "reset:dev": "prisma migrate reset --force --skip-seed && pnpm seed:dev",
    "reset:test": "dotenv -e .env.test -- prisma migrate reset --force --skip-seed && pnpm seed:test",
    "reset:demo": "dotenv -e .env.demo -- prisma migrate reset --force --skip-seed && pnpm seed:demo"
  },
  "devDependencies": {
    "prisma": "^7.7.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0"
  }
}