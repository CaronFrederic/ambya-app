{
  "scripts": {
    "start:dev": "pnpm exec nest start --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed:dev": "tsx prisma/seed/main.seed.ts dev",
    "seed:test": "dotenv -e .env.test -- tsx prisma/seed/main.seed.ts test",
    "seed:demo": "dotenv -e .env.demo -- tsx prisma/seed/main.seed.ts demo",
    "reset:dev": "prisma migrate reset --force --skip-seed && pnpm seed:dev",
    "reset:test": "dotenv -e .env.test -- prisma migrate reset --force --skip-seed && pnpm seed:test",
    "reset:demo": "dotenv -e .env.demo -- prisma migrate reset --force --skip-seed && pnpm seed:demo"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.1",
    "node-fetch": "^2.7.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}