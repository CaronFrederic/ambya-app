{
  "scripts": {
    "start:dev": "dotenv -e .env -- pnpm exec nest start --watch",
    "start:test": "dotenv -e .env.test -- pnpm exec nest start --watch",
    "start:demo": "dotenv -e .env.demo -- pnpm exec nest start --watch",

    "db:generate": "pnpm exec prisma generate",
    "db:studio": "dotenv -e .env -- pnpm exec prisma studio",

    "db:push:dev": "dotenv -e .env -- pnpm exec prisma db push",
    "db:push:test": "dotenv -e .env.test -- pnpm exec prisma db push",
    "db:push:demo": "dotenv -e .env.demo -- pnpm exec prisma db push",

    "seed:dev": "dotenv -e .env -- pnpm exec tsx prisma/seed/main.seed.ts",
    "seed:test": "dotenv -e .env.test -- pnpm exec tsx prisma/seed/main.seed.ts",
    "seed:demo": "dotenv -e .env.demo -- pnpm exec tsx prisma/seed/main.seed.ts",

    "reset:dev": "dotenv -e .env -- pnpm exec prisma migrate reset --force",
    "reset:test": "dotenv -e .env.test -- pnpm exec prisma migrate reset --force",
    "reset:demo": "dotenv -e .env.demo -- pnpm exec prisma migrate reset --force",

    "check:pro:dev": "dotenv -e .env -- pnpm exec tsx scripts/checks/check-pro-suite.ts",
    "check:pro:test": "dotenv -e .env.test -- pnpm exec tsx scripts/checks/check-pro-suite.ts",
    "check:pro:demo": "dotenv -e .env.demo -- pnpm exec tsx scripts/checks/check-pro-suite.ts",

    "check:pro:crud:dev": "dotenv -e .env -- pnpm exec tsx scripts/checks/check-pro-crud-suite.ts",
    "check:pro:crud:test": "dotenv -e .env.test -- pnpm exec tsx scripts/checks/check-pro-crud-suite.ts",
    "check:pro:crud:demo": "dotenv -e .env.demo -- pnpm exec tsx scripts/checks/check-pro-crud-suite.ts",

    "check:pro:full:dev": "pnpm check:pro:dev && pnpm check:pro:crud:dev",
    "check:pro:full:test": "pnpm check:pro:test && pnpm check:pro:crud:test",
    "check:pro:full:demo": "pnpm check:pro:demo && pnpm check:pro:crud:demo"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.1",
    "exceljs": "^4.4.0",
    "node-fetch": "^2.7.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}