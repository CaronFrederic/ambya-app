generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  PROFESSIONAL
  SALON_MANAGER
  EMPLOYEE
  ADMIN
}

enum AdminScope {
  SUPER_ADMIN
  SUPPORT
  OPS
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  REJECTED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum EmployeeSpecialty {
  HAIR_STYLIST
  ESTHETICIAN
  BARBER
  MASSAGE_THERAPIST
  MANICURIST
  FITNESS_COACH
  OTHER
}

enum ServiceCategory {
  HAIR
  BARBER
  NAILS
  FACE
  BODY
  FITNESS
  BEAUTE
  BIENETRE
  FORMATION
  OTHER
}

enum AppointmentSource {
  CLIENT_APP
  PRO_DASHBOARD
  EMPLOYEE
  IMPORT
}

enum EmployeeStatus {
  ACTIVE
  LEAVE
  ABSENT
  INACTIVE
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  ACCEPTED
  REJECTED
  REFUSED
}

enum AbsenceSource {
  MANUAL
  LEAVE_REQUEST
  SYSTEM
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PaymentType {
  MOMO
  CARD
  CASH
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoyaltyReason {
  WELCOME
  BOOKING
  REVIEW
  REFERRAL
  ADJUSTMENT
}

enum PaymentStatus {
  CREATED
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum ExpenseStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum ClientPreferenceType {
  SERVICE
  EMPLOYEE
  SCHEDULE
  OTHER
}

enum LoginMethod {
  PHONE
  EMAIL
}

enum SalonPayoutMethod {
  MOBILE_MONEY
  BANK
}

enum MobileMoneyOperator {
  AIRTEL
  MOOV
  MTN
  ORANGE
}

model User {
  id       String   @id @default(cuid())
  email    String?  @unique
  phone    String?  @unique
  password String?
  role     UserRole @default(CLIENT)
  isActive Boolean  @default(true)

  phoneVerified        Boolean      @default(false)
  emailVerified        Boolean      @default(false)
  otpCode              String?
  otpExpiresAt         DateTime?
  otpChannel           LoginMethod?
  preferredLoginMethod LoginMethod?

  acceptedTermsAt         DateTime?
  acceptedNotificationsAt DateTime?
  acceptedNewsletterAt    DateTime?

  ownedSalons     Salon[]       @relation("SalonOwner")
  employeeProfile Employee?     @relation("EmployeeUser")
  adminProfile    AdminProfile?

  appointments   Appointment[]   @relation("AppointmentClient")
  reviews        SalonReview[]
  clientProfile  ClientProfile?
  paymentMethods PaymentMethod[]
  loyaltyAccount LoyaltyAccount?
  paymentIntents PaymentIntent[]

  salonMemberships SalonClient[] @relation("SalonClientUser")

  createdAppointments   Appointment[]          @relation("AppointmentCreatedBy")
  createdExpenses       Expense[]              @relation("ExpenseCreatedBy")
  reviewedLeaveRequests EmployeeLeaveRequest[] @relation("LeaveReviewedBy")
  createdAbsences       EmployeeAbsence[]      @relation("AbsenceCreatedBy")
  clientNotesCreated    ClientNote[]           @relation("ClientNoteCreatedBy")
  clientNotesUpdated    ClientNote[]           @relation("ClientNoteUpdatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
  @@index([phoneVerified])
  @@index([emailVerified])
}

model AdminProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String?
  lastName  String?
  scope     AdminScope @default(SUPPORT)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope])
}

model Salon {
  id                String  @id @default(cuid())
  name              String
  description       String?
  address           String?
  city              String?
  country           String?
  latitude          Float?
  longitude         Float?
  phone             String?
  email             String?
  coverImageUrl     String?
  galleryImageUrls  Json?
  socialLinks       Json?
  websiteUrl        String?
  instagramHandle   String?
  tiktokHandle      String?
  facebookUrl       String?
  showInstagramFeed Boolean @default(false)
  showTikTokFeed    Boolean @default(false)

  establishmentType String?
  district          String?
  categories        String[] @default([])

  teamSize     Int?
  workstations Int?

  paymentMethod       SalonPayoutMethod?
  mobileMoneyOperator MobileMoneyOperator?
  mobileMoneyNumber   String?

  currency String @default("XAF")
  timezone String @default("Africa/Libreville")

  depositEnabled    Boolean @default(false)
  depositPercentage Int     @default(30)

  paymentSettings  Json?
  openingHoursJson Json?

  isActive Boolean @default(true)

  onboardingCompleted Boolean @default(false)

  ownerId String
  owner   User   @relation("SalonOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  employees      Employee[]
  services       Service[]
  appointments   Appointment[]
  blockedSlots   EmployeeBlockedSlot[]
  reviews        SalonReview[]
  paymentIntents PaymentIntent[]
  openingHours   SalonOpeningHour[]
  expenses       Expense[]
  promotions     Promotion[]
  salonClients   SalonClient[]
  clientNotes    ClientNote[]
  leaveRequests  EmployeeLeaveRequest[]
  absences       EmployeeAbsence[]
  salonSchedules SalonSchedule[]
  loyaltyConfig  LoyaltyConfig?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([isActive])
  @@index([paymentMethod])
  @@index([onboardingCompleted])
}

model Employee {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  userId String @unique
  user   User   @relation("EmployeeUser", fields: [userId], references: [id], onDelete: Cascade)

  firstName   String?
  lastName    String?
  displayName String
  roleLabel   String?
  photoUrl    String?
  phone       String?
  email       String?

  status   EmployeeStatus @default(ACTIVE)
  isActive Boolean        @default(true)
  hireDate DateTime?

  appointments        Appointment[]
  appointmentServices AppointmentService[]
  schedules           EmployeeSchedule[]
  leaveRequests       EmployeeLeaveRequest[]
  simpleLeaveRequests LeaveRequest[]
  absences            EmployeeAbsence[]
  preferredByClients  SalonClientPreferredEmployee[]
  specialties         EmployeeSpecialtyAssignment[]
  blockedSlots        EmployeeBlockedSlot[]
  clientPreferences   ClientPreference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([isActive])
  @@index([status])
}

model EmployeeSpecialtyAssignment {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  specialty EmployeeSpecialty

  createdAt DateTime @default(now())

  @@unique([employeeId, specialty])
  @@index([specialty])
}

model Service {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    ServiceCategory @default(OTHER)
  price       Int
  durationMin Int

  isActive  Boolean       @default(true)
  status    ServiceStatus @default(ACTIVE)
  deletedAt DateTime?

  appointments        Appointment[]
  appointmentServices AppointmentService[]
  promotionLinks      PromotionService[]
  blockedSlots        EmployeeBlockedSlot[]
  clientPreferences   ClientPreference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, name])
  @@index([salonId])
  @@index([category])
  @@index([isActive])
  @@index([status])
}

model Appointment {
  id     String            @id @default(cuid())
  status AppointmentStatus @default(PENDING)
  source AppointmentSource @default(PRO_DASHBOARD)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  clientId String
  client   User   @relation("AppointmentClient", fields: [clientId], references: [id], onDelete: Cascade)

  salonClientId String?
  salonClient   SalonClient? @relation(fields: [salonClientId], references: [id], onDelete: SetNull)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  paymentIntents      PaymentIntent[]
  appointmentServices AppointmentService[]

  startAt DateTime
  endAt   DateTime

  note String?

  subtotalAmount  Int @default(0)
  discountAmount  Int @default(0)
  totalAmount     Int @default(0)
  depositAmount   Int @default(0)
  remainingAmount Int @default(0)

  createdById String?
  createdBy   User?   @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, startAt])
  @@index([clientId, startAt])
  @@index([employeeId, startAt])
  @@index([status])
}

model AppointmentService {
  id String @id @default(cuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  serviceNameSnapshot String
  durationMinSnapshot Int
  priceSnapshot       Int

  createdAt DateTime @default(now())

  @@index([appointmentId])
}

model EmployeeBlockedSlot {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  clientName  String
  clientPhone String
  note        String?
  startAt     DateTime
  endAt       DateTime
  status      AppointmentStatus @default(CONFIRMED)
  isPaid      Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, startAt])
  @@index([employeeId, startAt])
  @@index([status])
}

model LeaveRequest {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  startAt     DateTime
  endAt       DateTime
  reason      String
  status      LeaveRequestStatus @default(PENDING)
  reviewedAt  DateTime?
  managerNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, createdAt])
  @@index([status])
}

model SalonReview {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  clientId String
  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  rating  Int
  comment String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, createdAt])
  @@index([clientId, createdAt])
}

model Country {
  code     String  @id
  name     String
  currency String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model ClientProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nickname String
  gender   String
  ageRange String
  city     String
  country  String

  allergies String?
  comments  String?

  questionnaire Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([country])
}

model PaymentMethod {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         PaymentType
  provider     String?
  providerRef  String?
  providerData Json?
  label        String?
  phone        String?
  last4        String?
  isDefault    Boolean     @default(false)
  isActive     Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
}

model LoyaltyAccount {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier           LoyaltyTier @default(BRONZE)
  currentPoints  Int         @default(0)
  lifetimePoints Int         @default(0)

  transactions LoyaltyTransaction[]

  pendingDiscountAmount           Int          @default(0)
  pendingDiscountTier             LoyaltyTier?
  pendingDiscountIssuedAt         DateTime?
  pendingDiscountConsumedAt       DateTime?
  pendingDiscountConsumedIntentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltyTransaction {
  id String @id @default(cuid())

  loyaltyAccountId String
  loyaltyAccount   LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)

  deltaPoints Int
  reason      LoyaltyReason
  meta        Json?
  createdAt   DateTime      @default(now())

  @@index([loyaltyAccountId, createdAt])
}

model PaymentIntent {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  salonId String?
  salon   Salon?  @relation(fields: [salonId], references: [id], onDelete: SetNull)

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  amount              Int
  discountAmount      Int          @default(0)
  payableAmount       Int          @default(0)
  appliedDiscountTier LoyaltyTier?
  currency            String

  type            PaymentType?
  transactionDate DateTime     @default(now())

  status PaymentStatus @default(CREATED)

  provider     String?
  providerRef  String?
  providerData Json?

  platformFeeAmount Int @default(0)
  providerFeeAmount Int @default(0)
  netAmount         Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([salonId, createdAt])
  @@index([appointmentId])
  @@index([status])
  @@index([transactionDate])
  @@index([type])
}

model SalonClient {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  clientId String
  client   User   @relation("SalonClientUser", fields: [clientId], references: [id], onDelete: Cascade)

  isRegular       Boolean @default(false)
  isBlocked       Boolean @default(false)
  isDepositExempt Boolean @default(false)

  loyaltyPoints Int @default(0)

  firstVisitAt DateTime?
  lastVisitAt  DateTime?

  totalSpent     Int @default(0)
  bookingCount   Int @default(0)
  completedCount Int @default(0)
  canceledCount  Int @default(0)
  noShowCount    Int @default(0)

  appointments       Appointment[]
  notes              ClientNote[]
  preferences        ClientPreference[]
  preferredEmployees SalonClientPreferredEmployee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, clientId])
  @@index([salonId])
  @@index([clientId])
}

model ClientNote {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  salonClientId String
  salonClient   SalonClient @relation(fields: [salonClientId], references: [id], onDelete: Cascade)

  content String

  createdById String?
  createdBy   User?   @relation("ClientNoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   User?   @relation("ClientNoteUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, salonClientId])
}

model ClientPreference {
  id String @id @default(cuid())

  salonClientId String
  salonClient   SalonClient @relation(fields: [salonClientId], references: [id], onDelete: Cascade)

  type  ClientPreferenceType
  value String

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([salonClientId, type])
}

model SalonClientPreferredEmployee {
  id String @id @default(cuid())

  salonClientId String
  salonClient   SalonClient @relation(fields: [salonClientId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  count Int @default(0)

  @@unique([salonClientId, employeeId])
}

model EmployeeLeaveRequest {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  subject     String
  reason      String?
  startDate   DateTime
  endDate     DateTime?
  requestDate DateTime  @default(now())

  status LeaveRequestStatus @default(PENDING)

  reviewedById String?
  reviewedBy   User?     @relation("LeaveReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?

  linkedAbsence EmployeeAbsence?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, status])
  @@index([employeeId])
}

model EmployeeAbsence {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  leaveRequestId String?               @unique
  leaveRequest   EmployeeLeaveRequest? @relation(fields: [leaveRequestId], references: [id], onDelete: SetNull)

  reason    String?
  startDate DateTime
  endDate   DateTime?
  source    AbsenceSource @default(MANUAL)

  createdById String?
  createdBy   User?   @relation("AbsenceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([salonId, employeeId])
}

model EmployeeSchedule {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  startTime String
  endTime   String
  isWorking Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, dayOfWeek])
}

model SalonSchedule {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  startTime String
  endTime   String
  isOpen    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, dayOfWeek])
}

model Expense {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  category    String
  description String?
  amount      Int
  expenseDate DateTime
  receiptUrl  String?

  status    ExpenseStatus @default(CONFIRMED)
  deletedAt DateTime?

  createdById String?
  createdBy   User?   @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, expenseDate])
  @@index([status])
}

model Promotion {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        PromotionType
  value       Int

  startDate DateTime
  endDate   DateTime

  isActive             Boolean @default(true)
  appliesToAllServices Boolean @default(false)

  services PromotionService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, isActive])
}

model PromotionService {
  promotionId String
  serviceId   String

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([promotionId, serviceId])
}

model LoyaltyConfig {
  id String @id @default(cuid())

  salonId String @unique
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  enabled         Boolean @default(false)
  cardName        String?
  pointsPerVisit  Int     @default(0)
  pointsPerAmount Int     @default(0)
  rewardRulesJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalonOpeningHour {
  id String @id @default(cuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  isOpen    Boolean @default(true)
  startTime String
  endTime   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([salonId, dayOfWeek])
}

model AuditLog {
  id String @id @default(cuid())

  actionType      String
  entityType      String
  entityId        String?
  actorUserId     String?
  actorRole       UserRole?
  actorAdminScope AdminScope?
  requestId       String?
  route           String?
  method          String?
  oldValue        Json?
  newValue        Json?
  metadata        Json?

  createdAt DateTime @default(now())

  @@index([actionType, createdAt])
  @@index([entityType, createdAt])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
}
